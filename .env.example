# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=PlaceMentor AI
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ─── Database (Neon free tier: https://neon.tech) ─────────────────────────────
POSTGRES_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Upstash free tier: https://upstash.com) ──────────────────────────
REDIS_URL=rediss://default:password@xxx.upstash.io:6380

# ─── Pinecone (free tier: https://pinecone.io) ────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=placementor

# ─── LLM API Keys ─────────────────────────────────────────────────────────────
# Get free Groq key: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Get free Google key: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# ─── LangSmith (optional) ─────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=placementor-ai
